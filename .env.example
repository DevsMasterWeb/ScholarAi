# GOOGLE_AI_API_KEY: Use this to provide a manual API key if GEMINI_API_KEY (platform managed) fails.
GOOGLE_AI_API_KEY="PASTE_YOUR_ACTUAL_AI_STUDIO_KEY_HERE"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Tavily API Key for research searching
TAVILY_API_KEY="MY_TAVILY_API_KEY"

# Groq API Key for Llama 3.1
GROQ_API_KEY="MY_GROQ_API_KEY"

# Pinecone API Key for Vector Database
PINECONE_API_KEY="MY_PINECONE_API_KEY"
